{
  "branches": ["main"],
  "repositoryUrl": "https://github.com/JoRouquette/vps-publish",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      { "changelogFile": "CHANGELOG.md" }
    ],
    [
      "@semantic-release/exec",
      {
        "verifyConditionsCmd": "echo 'Ready for release'",
        "prepareCmd": "node scripts/version-bump.mjs"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["manifest.json", "versions.json", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          { "path": "main.js", "label": "main.js" },
          { "path": "manifest.json", "label": "manifest.json" },
          { "path": "styles.css", "label": "styles.css" },
          { "path": "versions.json", "label": "versions.json" }
        ]
      }
    ]
  ]
}
